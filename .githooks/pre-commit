#!/bin/bash

BRANCH=$(git symbolic-ref --short HEAD)
REMOTE="origin"

# Fetch silencioso para tener el estado actualizado
git fetch "$REMOTE" "$BRANCH" --quiet 2>/dev/null

LOCAL=$(git rev-parse HEAD)
REMOTE_HEAD=$(git rev-parse "$REMOTE/$BRANCH" 2>/dev/null)

if [ -z "$REMOTE_HEAD" ]; then
  exit 0  # rama no existe en remoto todavía, ok
fi

BEHIND=$(git rev-list --count HEAD.."$REMOTE/$BRANCH")

if [ "$BEHIND" -gt 0 ]; then
  echo ""
  echo "❌ Tu rama '$BRANCH' está $BEHIND commit(s) detrás de $REMOTE/$BRANCH"
  echo ""
  echo "   Corré: git pull origin $BRANCH --rebase"
  echo ""
  exit 1
fi
