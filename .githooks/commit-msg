#!/bin/bash

MSG=$(cat "$1")
PATTERN="^(feat|fix|docs|style|refactor|perf|test|chore|ci|build|revert)(\(.+\))?: .{1,100}"

if ! echo "$MSG" | grep -qP "$PATTERN"; then
  echo ""
  echo "❌ Mensaje de commit inválido: '$MSG'"
  echo ""
  echo "   Formato requerido: <tipo>(scope opcional): descripción"
  echo "   Ejemplos:"
  echo "     feat: agregar encoder Reed-Solomon"
  echo "     fix(decoder): corregir índice fuera de rango"
  echo "     chore: actualizar dependencias"
  echo ""
  echo "   Tipos válidos: feat fix docs style refactor perf test chore ci build revert"
  echo ""
  exit 1
fi
