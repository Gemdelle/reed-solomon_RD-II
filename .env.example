# ── Server (control plane) ────────────────────────────────────────────────────
# HEARTBEAT_TTL_S=30
# REDIS_URL=redis://localhost:6379/0

# Keycloak OIDC (leave disabled for dev mode)
# OIDC_ENABLED=true
# OIDC_ISSUER=http://localhost:8081/realms/rockdove
# OIDC_ISSUER_PUBLIC=http://localhost:8081/realms/rockdove
# OIDC_CLIENT_ID=rockdove-client

# Invite tokens (change secret in production!)
# INVITE_SECRET=change-me-in-production

# Headless agent service account (optional)
# AGENT_SERVICE_TOKEN=your-secret-service-token

# ── Agent (client data plane — one .env per peer) ─────────────────────────────
SERVER_URL=http://localhost:8080
PEER_ID=peer-alice
AGENT_API_URL=http://192.168.1.10:8000
UDP_HOST=0.0.0.0
UDP_PORT=9001
STORAGE_PATH=./data
NETWORK_HINT=auto

# Agent authentication (choose one):
# AGENT_SERVICE_TOKEN=your-secret-service-token  # service account
# INVITE_TOKEN=eyJ...                             # single-use invite
